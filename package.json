{
  "name": "marslib-vscode",
  "displayName": "MARSLib Extension",
  "description": "Official VS Code extension for the MARSLib robotics framework.",
  "version": "1.0.5",
  "publisher": "mars2614",
  "icon": "resources/mars-logo.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/mars2614/marslib-vscode"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:marslib-actions",
    "onView:marslib-canids",
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "marslib-actions-container",
          "title": "MARSLib",
          "icon": "resources/marslib.svg"
        }
      ]
    },
    "views": {
      "marslib-actions-container": [
        {
          "id": "marslib-actions",
          "name": "Commands",
          "type": "tree"
        },
        {
          "id": "marslib-canids",
          "name": "MARSLib CAN IDs",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "marslib.build",
        "title": "MARSLib: Build Robot Code"
      },
      {
        "command": "marslib.deploy",
        "title": "MARSLib: Deploy Robot Code"
      },
      {
        "command": "marslib.simulate",
        "title": "MARSLib: Simulate Robot Code"
      },
      {
        "command": "marslib.generateSubsystem",
        "title": "MARSLib: Generate Subsystem (AdvantageKit)"
      },
      {
        "command": "marslib.audit",
        "title": "MARSLib: Run Audit"
      },
      {
        "command": "marslib.setupEnvironment",
        "title": "MARSLib: Setup Development Environment"
      },
      {
        "command": "marslib.openLog",
        "title": "MARSLib: Open Latest Log in AdvantageScope"
      },
      {
        "command": "marslib.refreshCANIds",
        "title": "Refresh CAN IDs",
        "icon": "$(refresh)"
      },
      {
        "command": "marslib.openDashboard",
        "title": "MARSLib: Open Virtual Dashboard"
      },
      {
        "command": "marslib.generateTest",
        "title": "MARSLib: Generate Physics Test"
      },
      {
        "command": "marslib.openBinder",
        "title": "MARSLib: Open Command Binder"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "marslib.refreshCANIds",
          "when": "view == marslib-canids",
          "group": "navigation"
        }
      ]
    },
    "snippets": [
      {
        "language": "java",
        "path": "./snippets/marslib.code-snippets"
      }
    ],
    "walkthroughs": [
      {
        "id": "marslib.welcome",
        "title": "Welcome to MARSLib",
        "description": "Getting started with championship-grade robotics development.",
        "steps": [
          {
            "id": "setup",
            "title": "Initialize Environment",
            "description": "Download core FRC libraries and configure your git hooks. This ensures your project follows the Elite Coding Standards.",
            "media": {
              "svg": "resources/marslib.svg",
              "altText": "MARSLib Logo"
            },
            "completionEvents": [
              "onCommand:marslib.setupEnvironment"
            ],
            "button": {
              "command": "marslib.setupEnvironment"
            }
          },
          {
            "id": "generate",
            "title": "Scaffold a Subsystem",
            "description": "Use the MARSLib Generator to create your first AdvantageKit-ready mechanism with IO layers.",
            "button": {
              "command": "marslib.generateSubsystem"
            }
          },
          {
            "id": "canids",
            "title": "Review CAN IDs",
            "description": "Open the MARSLib CAN ID Manager in the sidebar to visualize your hardware mapping and detect conflicts.",
            "button": {
              "command": "workbench.view.extension.marslib-actions-container"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.1",
    "@types/node": "20.2.5",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^5.59.8",
    "@typescript-eslint/parser": "^5.59.8",
    "eslint": "^8.41.0",
    "glob": "^8.1.0",
    "mocha": "^10.2.0",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "ntcore-ts-client": "^3.1.3"
  }
}
